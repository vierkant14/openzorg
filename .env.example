# OpenZorg environment variables
# Copy to .env and adjust as needed

# PostgreSQL
POSTGRES_DB=openzorg
POSTGRES_USER=openzorg
POSTGRES_PASSWORD=openzorg_dev_password

# Medplum
MEDPLUM_BASE_URL=http://localhost:8103
MEDPLUM_CLIENT_ID=
MEDPLUM_PROJECT_ID=
MEDPLUM_SUPER_ADMIN_EMAIL=admin@openzorg.local
MEDPLUM_SUPER_ADMIN_PASSWORD=SuperAdmin123!

# Services
ECD_PORT=4001
PLANNING_PORT=4002
FACTURATIE_PORT=4003
WORKFLOW_BRIDGE_PORT=4004
